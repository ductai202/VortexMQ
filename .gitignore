## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is for .NET projects.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache models, build results, and settings
.vs/
# Uncomment if you use a Visual Studio version lower than 2015
# *.suo
# *.user
# *.sln.docstates

# Visual Studio Code
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image recurse caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on secondary drives
$RECYCLE.BIN/

# VS Code files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
appsettings.Development.json

# Rider
.idea/
*.sln.iml

# NuGet Packages
*.nupkg
# The NuGet offline cache is still used by some tools
# .nuget/
# .nuget/packages/
# NuGet.Config
# NuGet.exe

# Microsoft Azure Build Output
GetBuildID.ps1
PublishScripts/

# ncrunch files
*ncrunch*
*crunch*.local.xml
nCrunchTemp_*

# Benchmarking
BenchmarkDotNet.Artifacts/

# Others
.DS_Store

# Persistence Data
broker_data/
